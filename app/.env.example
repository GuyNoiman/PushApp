# PushApp — environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored; this `.env.example` is committed as documentation.
#
# Supabase (POC social/Allies pillar — Free tier). Client-safe values only.
# Get these from Supabase → Project Settings → API. NEVER put the secret (service_role) key here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
